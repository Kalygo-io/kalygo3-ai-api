{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kalygo.example/schemas/agent-v4.schema.json",
  "title": "Agent v4",
  "description": "Agent schema v4 - adds optional ElevenLabs voice ID for TTS/voice anthropomorphization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "config"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable agent name."
    },
    "description": {
      "type": "string",
      "description": "Optional description of what the agent does."
    },
    "config": {
      "type": "object",
      "required": [
        "schema",
        "version",
        "data"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "const": "agent_config"
        },
        "version": {
          "type": "integer",
          "const": 4
        },
        "data": {
          "type": "object",
          "required": [
            "systemPrompt"
          ],
          "properties": {
            "systemPrompt": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "object",
              "required": ["provider", "model"],
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": ["openai", "anthropic", "ollama"]
                },
                "model": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "elevenlabsVoiceId": {
              "type": "string",
              "minLength": 1,
              "description": "Optional ElevenLabs voice ID for TTS."
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "description": "Agent configuration v4 (systemPrompt, model, elevenlabsVoiceId, tools, etc.)."
    }
  }
}
